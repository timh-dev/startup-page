  },
  "dependencies": {
    "@clerk/backend": "^3.12.0",
    "@clerk/clerk-react": "^5.61.9",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@paper-design/shaders-react": "^0.0.77",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "js-cookie": "^3.0.8",
    "kbar": "0.1.0-beta.48",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "scripts": {
    "deploy": "pnpm run build && gh-pages -d dist",
    "dev": "vite --open",
    "start": "pnpm run dev",
    "build": "vite build",
    "build:local": "vite build --base \"/\"",
    "build:vercel": "node scripts/migrate.mjs && vite build --base \"/\"",
    "preview": "vite preview",
    "serve": "vite preview --host 0.0.0.0 --port 8000",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "autoprefixer": "^10.5.4",
    "drizzle-kit": "^0.31.10",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.22",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  },
  "pnpm": {
    "allowBuilds": {
      "@clerk/shared": true,
      "esbuild": true
    },
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "esbuild"
    ]
  }
}
